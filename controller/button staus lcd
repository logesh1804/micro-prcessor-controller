#include<reg52.h>
#define LCD P2
sbit en=P3^0;
sbit rw=P3^1;
sbit rs=P3^2;
sbit bt=P3^3;
 void delay(){
	 int i;
	 for(i=0;i<10000;i++);
 }
 
 void cmd(unsigned char c){
	 LCD=c;
	 rs=0;
	 rw=0;
	 en=1;
	 delay();
	 en=0;
 }
 void dat(unsigned char d){
	 LCD =d;
	 rs=1;
	 rw=0;
	 en=1;
	 delay();
	 en=0;
 }
 void str(char *c){
	 while(*c){
	 dat(*c++);
	
	 delay();
		 
 }
 }
 	 void fun1(){
cmd(0x38);
cmd(0x0C);
cmd(0x06);
cmd (0x80);
	
str("pressed");
	 }
 void fun2(){
	 cmd(0x38);
cmd(0x0C);
cmd(0x06);
cmd (0x80);
str("not pressed");
	 
 }
	 
 
 void main(){
	 
	 if (bt==0){
		 
	 fun1();
	 }
	 else{
		 fun2();
	 }
	 while(1);
 }
	 

	 
