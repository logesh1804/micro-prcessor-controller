#include <reg51.h>

#define LCD P1

sbit RS = P2^0;
sbit RW = P2^1;
sbit EN = P2^2;

void delay() {
    int i,j;
    for(i=0;i<100;i++)
        for(j=0;j<1275;j++);
}

void lcd_cmd(unsigned char cmd) {
    LCD = cmd;
    RS = 0;
    RW = 0;
    EN = 1;
    delay();
    EN = 0;
}

void lcd_data(unsigned char dat) {
    LCD = dat;
    RS = 1;
    RW = 0;
    EN = 1;
    delay();
    EN = 0;
}

void lcd_init() {
    lcd_cmd(0x38);
    lcd_cmd(0x0C);
    lcd_cmd(0x06);
    lcd_cmd(0x01);
}

void lcd_string(char *str) {
    while(*str) {
        lcd_data(*str++);
    }
}

void main() {
    lcd_init();

    lcd_cmd(0x80);           // Line 1
    lcd_string("8051");

    lcd_cmd(0xC0);           // Line 2
    lcd_string("EMBEDDED");

    while(1);
}
