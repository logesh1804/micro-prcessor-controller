#include<reg52.h>
#define LCD P2
sbit en=P3^0;
sbit rw=P3^1;
sbit rs=P3^2;
 void delay(){
	 int i;
	 for(i=0;i<10000;i++);
 }
 
 void cmd(unsigned char c){
	 LCD=c;
	 rs=0;
	 rw=0;
	 en=1;
	 delay();
	 en=0;
 }
 void dat(unsigned char d){
	 LCD =d;
	 rs=1;
	 rw=0;
	 en=1;
	 delay();
	 en=0;
 }
 void str(char *c){
	 while(*c){
	 dat(*c++);
	
	 delay();
		 
 }
 cmd(0x18);
 }
 void main(){
cmd(0x38);
cmd(0x0C);
cmd(0x06);
cmd (0x80);
	
str("logesh"); 
