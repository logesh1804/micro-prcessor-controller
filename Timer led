#include <reg52.h>

sbit LED = P1^0;

void timer0_ISR(void) interrupt 1 {
    TH0 = 0xFC;   // Reload value
    TL0 = 0x66;

    LED = ~LED;   // Toggle LED
}

void main() {
    TMOD = 0x01;  // Timer0 mode1

    TH0 = 0xFC;
    TL0 = 0x66;

    IE = 0x82;    // Enable Timer0 interrupt + global interrupt

    TR0 = 1;      // Start timer

    while(1);     // Do nothing (interrupt handles work)
}
